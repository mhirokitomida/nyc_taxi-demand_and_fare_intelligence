# Shared Spark local cluster settings for the MVP bootstrap only.
SPARK_RPC_AUTHENTICATION_ENABLED=no
SPARK_RPC_ENCRYPTION_ENABLED=no
SPARK_LOCAL_STORAGE_ENCRYPTION_ENABLED=no
SPARK_SSL_ENABLED=no
SPARK_USER=spark
# Validation target after `docker compose up`: Spark master UI should answer on http://localhost:8081
